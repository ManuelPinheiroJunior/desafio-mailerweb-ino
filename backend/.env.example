APP_NAME=meeting-room-backend
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meeting_room

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_EMAIL=admin@company.local

WORKER_POLL_INTERVAL_SECONDS=3
WORKER_BATCH_SIZE=20
WORKER_MAX_BACKOFF_SECONDS=1800
WORKER_PROCESSING_TIMEOUT_SECONDS=300
EMAIL_SENDER_ADDRESS=no-reply@meeting-room.local
